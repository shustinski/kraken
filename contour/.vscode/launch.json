{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Polygon Widget",
      "type": "python",
      "request": "launch",
      "module": "polygon_widget",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Polygon Widget With Pipeline",
      "type": "python",
      "request": "launch",
      "module": "polygon_widget",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--pipeline-json",
        "${workspaceFolder}\\polygon_widget\\pipeline_example.json"
      ]
    }
  ]
}
